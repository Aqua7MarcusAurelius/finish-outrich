# ───────────────────────────────
# Приложение
# ───────────────────────────────
APP_ENV=development
APP_PORT=8000
API_TOKEN=change_me_to_random_string
DOCS_PUBLIC=true

# ───────────────────────────────
# CORS
# ───────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ───────────────────────────────
# PostgreSQL
# ───────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tgframework
POSTGRES_USER=tgframework
POSTGRES_PASSWORD=change_me

# ───────────────────────────────
# Redis
# ───────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ───────────────────────────────
# MinIO
# ───────────────────────────────
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_BUCKET=tgframework

# ───────────────────────────────
# OpenRouter
# ───────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL_TRANSCRIPTION=openai/whisper
OPENROUTER_MODEL_DESCRIPTION=openai/gpt-4o

# Telegram API (получить на https://my.telegram.org — один раз для всего приложения)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=